# .env.example
# Copy this to envs/person_a.env and fill in real values
# This file is committed — it documents what variables are needed
# The actual envs/ folder is gitignored

HAP_ID=
EMAIL=
GIVEN_NAMES=
FAMILY_NAME=
DOB=
PREFERRED_LOCATION=
CURRENT_APPT_DATE=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Timing between checks in minutes — bot picks random value in this range
# Increase to reduce site hit frequency
# Recommended production: MIN=15, MAX=45
CHECK_INTERVAL_MIN=2
CHECK_INTERVAL_MAX=3

HEADLESS=true
BUPA_URL=https://bmvs.onlineappointmentscheduling.net.au/oasis/Search.aspx
BASE_DIR=
CONTAINER_NAME=